# B站 Cookie（必填）
# 登录 bilibili.com → F12 → Network → 刷新 → 任意请求的 Cookie 头
# 需要：SESSDATA, bili_jct, DedeUserID
# 注意：SESSDATA 是 HttpOnly，只能从 Network 请求头获取，Application 面板看不到
BILI_COOKIE="SESSDATA=xxx; bili_jct=xxx; DedeUserID=xxx"

# 收藏夹 ID（必填）
# 打开B站收藏夹页面，URL 中的 media_id 数字
# 或调用 API：curl -H "Cookie: $BILI_COOKIE" "https://api.bilibili.com/x/v3/fav/folder/created/list-all?up_mid=$DedeUserID"
BILI_FAV_MEDIA_IDS="YOUR_MEDIA_ID_HERE"

# Obsidian Vault 路径（必填）
OBSIDIAN_VAULT="/absolute/path/to/Obsidian/Vault"

# Obsidian 收藏夹笔记子目录（可选，默认 Bilibili Inbox）
OBSIDIAN_INBOX="Bilibili Inbox"

# 时区（可选，默认 Asia/Shanghai）
BILI_SYNC_TZ="Asia/Shanghai"

# Whisper 代理（可选，yt-dlp 下载音频时使用）
# BILI_PROXY="http://127.0.0.1:7897"
